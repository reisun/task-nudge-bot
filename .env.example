# TickTick OAuth2
TICKTICK_CLIENT_ID=your-client-id
TICKTICK_CLIENT_SECRET=your-client-secret
TICKTICK_REDIRECT_URI=http://localhost:8080/callback

# TickTick V2 API (習慣機能用)
TICKTICK_USERNAME=your-username
TICKTICK_PASSWORD=your-password

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=C0123456789

# Scheduler (optional)
# NOTIFY_HOURS 優先（カンマ区切り）、未設定なら START-END の毎時実行
NOTIFY_HOURS=7,10,13,16,19,22
# NOTIFY_START_HOUR=7
# NOTIFY_END_HOUR=23
NOTIFY_CRON_MINUTE=0
TZ=Asia/Tokyo
